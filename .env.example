# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DROP_ADDRESS=drop@dropnote.com

# ============================================================
# SendGrid — inbound email webhook
# ============================================================
# A secret token appended as ?key= to the /api/ingest webhook URL.
# Configure the same value in SendGrid's Inbound Parse webhook URL.
SENDGRID_INGEST_SECRET=your-sendgrid-ingest-secret

# ============================================================
# Upstash Redis — rate limiting (REST API, web app)
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================================
# Redis — BullMQ job queue (TCP, worker)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# Resend — transactional email
# ============================================================
RESEND_API_KEY=re_your_api_key
RESEND_FROM_ADDRESS=drop-note <hello@dropnote.com>

# ============================================================
# OpenAI — AI summarization and image description
# ============================================================
OPENAI_API_KEY=sk-your-openai-key
# Optional: override the AI model (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini
# AI_VISION_MODEL=gpt-4o-mini
